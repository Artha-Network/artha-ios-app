# ─── XcodeGen ─────────────────────────────────────────────────────────────────
# ArthaNetwork.xcodeproj is GENERATED by XcodeGen from project.yml.
# project.yml is the source of truth — never commit the generated project.
ArthaNetwork.xcodeproj/

# ─── Xcode user-local state ───────────────────────────────────────────────────
xcuserdata/
*.xcuserstate
*.xcuserdatad/

# ─── Build products ───────────────────────────────────────────────────────────
build/
DerivedData/
*.o
*.d
*.hmap
*.ipa
*.dSYM
*.dSYM.zip

# ─── Swift Package Manager ────────────────────────────────────────────────────
# .build/ and .swiftpm/ are local SPM caches.
# Package.resolved is inside ArthaNetwork.xcodeproj/ (already ignored above).
.build/
.swiftpm/
Packages/

# ─── CocoaPods (not used, but guarded in case) ────────────────────────────────
Pods/
Podfile.lock

# ─── Fastlane ─────────────────────────────────────────────────────────────────
fastlane/report.xml
fastlane/Preview.html
fastlane/screenshots/**/*.png
fastlane/test_output/

# ─── Secrets / environment ────────────────────────────────────────────────────
# Do NOT commit local environment overrides.
# Use Xcode scheme → Environment Variables instead. See README > Configuration.
.env
.env.*
*.env
Configs/*.local.xcconfig

# ─── macOS system files ───────────────────────────────────────────────────────
**/.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# ─── Simulator / test output ──────────────────────────────────────────────────
*.app/
TestResults/
